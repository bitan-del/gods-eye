{
  "name": "@godseye/qa-lab",
  "version": "2026.4.10",
  "private": true,
  "description": "OpenClaw QA lab plugin with private debugger UI and scenario runner",
  "type": "module",
  "devDependencies": {
    "@godseye/plugin-sdk": "workspace:*",
    "godseye": "workspace:*"
  },
  "peerDependencies": {
    "godseye": ">=2026.4.10"
  },
  "peerDependenciesMeta": {
    "godseye": {
      "optional": true
    }
  },
  "godseye": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@godseye/qa-lab",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.10"
    }
  }
}
