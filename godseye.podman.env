# Gods Eye Podman environment
# Copy to godseye.podman.env.local and set GODSEYE_GATEWAY_TOKEN (or use -e when running).
# This file can be used with:
#   GODSEYE_PODMAN_ENV=/path/to/godseye.podman.env ./scripts/run-godseye-podman.sh launch

# Required: gateway auth token. Generate with: openssl rand -hex 32
# Set this before running the container (or use run-godseye-podman.sh which can generate it).
GODSEYE_GATEWAY_TOKEN=

# Optional: web provider (leave empty to skip)
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=

# Host port mapping (defaults; override if needed)
GODSEYE_PODMAN_GATEWAY_HOST_PORT=18789
GODSEYE_PODMAN_BRIDGE_HOST_PORT=18790

# Gateway bind (used by the launch script)
GODSEYE_GATEWAY_BIND=lan

# Optional: LLM provider API keys (for zero cost use Ollama locally or Groq free tier)
# OLLAMA_API_KEY=ollama-local
# GROQ_API_KEY=
